{
  "expo": {
    "name": "Ferify",
    "slug": "ferify-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.ferify.app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ferify.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Ferify to use speech recognition for voice search.",
        "NSMicrophoneUsageDescription": "Allow Ferify to use the microphone for voice search."
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "com.ferify.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#080808"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ],
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080808"
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "enableAndroidX": true,
            "enableJetifier": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "usesCleartextTraffic": true,
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            },
            "extraMavenRepos": [
              "https://www.jitpack.io"
            ]
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Ferify to use the microphone for voice search.",
          "speechRecognitionPermission": "Allow Ferify to use speech recognition for voice search."
        }
      ],
      [
        "expo-gradle-jvmargs",
        "-Xmx2048m -XX:MaxMetaspaceSize=512m"
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e4f4dbf3-bf02-44d2-a560-b5168fc6e2f8"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/e4f4dbf3-bf02-44d2-a560-b5168fc6e2f8"
    }
  }
}
